<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields>
        <fieldset name="basic" label="Konfiguration">
            <field
                name="id"
                type="hidden"
                default="1"
            />

            <field
                name="general_vat_rate"
                type="number"
                label="Allgemeiner MwSt-Satz"
                step="0.01"
                min="0"
                required="true"
            />

            <field
                name="image_size_default"
                type="number"
                label="Bildgröße Standard"
                step="1"
                min="1"
                required="true"
            />

            <field
                name="image_size_small"
                type="number"
                label="Bildgröße Klein"
                step="1"
                min="1"
                required="true"
            />

            <field
                name="image_size_mobile"
                type="number"
                label="Bildgröße Mobile"
                step="1"
                min="1"
                required="true"
            />

            <field
                name="image_size_manufacturer"
                type="number"
                label="Bildgröße Hersteller"
                step="1"
                min="1"
                required="true"
            />

            <field
                name="show_terms_checkbox"
                type="radio"
                label="Checkbox für AGB anzeigen"
                default="0"
                class="btn-group btn-group-yesno"
            >
                <option value="1">Ja</option>
                <option value="0">Nein</option>
            </field>

            <field
                name="require_terms_checkbox"
                type="radio"
                label="Checkbox für AGB verpflichtend"
                default="0"
                class="btn-group btn-group-yesno"
            >
                <option value="1">Ja</option>
                <option value="0">Nein</option>
            </field>

            <field
                name="shipment_name"
                type="text"
                label="Versandname"
                size="60"
            />

            <field
                name="shipment_description"
                type="textarea"
                label="Versandbeschreibung"
                rows="5"
                cols="60"
                filter="raw"
            />

            <field
                name="shipment_color"
                type="color"
                label="Versandfarbe"
                default="#000000"
            />

            <field
                name="shipment_price"
                type="number"
                label="Versandpreis"
                step="0.0001"
                min="0"
            />

            <field
                name="is_published"
                type="radio"
                label="Versand veröffentlicht"
                default="1"
                class="btn-group btn-group-yesno"
            >
                <option value="1">Ja</option>
                <option value="0">Nein</option>
            </field>

            <field
                name="payment_name"
                type="text"
                label="Zahlungsname"
                size="60"
            />

            <field
                name="payment_description"
                type="textarea"
                label="Zahlungsbeschreibung"
                rows="5"
                cols="60"
                filter="raw"
            />

            <field
                name="payment_fee"
                type="number"
                label="Zahlungsgebühr"
                step="0.0001"
                min="0"
            />

            <field
                name="paypal_enabled"
                type="radio"
                label="PayPal aktiviert"
                default="0"
                class="btn-group btn-group-yesno"
            >
                <option value="1">Ja</option>
                <option value="0">Nein</option>
            </field>
        </fieldset>
    </fields>
</form>