<?xml version="1.0" encoding="utf-8"?>
<form>
	<fields name="filter">
		<field
			name="search"
			type="text"
			inputmode="search"
			hint="Bestellnummer suchen"
		/>

		<field
			name="status"
			type="sql"
			label="Status"
			class="js-select-submit-on-change"
			query="SELECT status_code AS value, status_name AS text FROM #__fdshop_order_statuses ORDER BY ordering ASC, id ASC"
			key_field="value"
			value_field="text"
			header="Status auswählen"
			translate_header="false"
		/>
	</fields>

	<fields name="list">
		<field
			name="fullordering"
			type="list"
			default="a.created DESC"
			class="js-select-submit-on-change"
		>
			<option value="a.created DESC">Neueste zuerst</option>
			<option value="a.created ASC">Älteste zuerst</option>
			<option value="a.order_number ASC">Bestellnummer ASC</option>
			<option value="a.order_number DESC">Bestellnummer DESC</option>
			<option value="a.id DESC">ID DESC</option>
			<option value="a.id ASC">ID ASC</option>
		</field>

		<field
			name="limit"
			type="limitbox"
			default="20"
			class="js-select-submit-on-change"
		/>
	</fields>
</form>