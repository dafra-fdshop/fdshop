<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields name="filter">
        <field
            name="search"
            type="text"
            inputmode="search"
            label="COM_FDSHOP_FILTER_SEARCH_LABEL"
            description="Hier können Sie nach Bundle-Nummer, Bundle-Name, Alias oder Beschreibung suchen"
            hint="Suche eingeben"
        />

        <field
            name="published"
            type="list"
            label="Status"
            class="js-select-submit-on-change"
        >
            <option value="">Status auswählen</option>
            <option value="1">Veröffentlicht</option>
            <option value="0">Deaktiviert</option>
        </field>
    </fields>

    <fields name="list">
        <field
            name="fullordering"
            type="list"
            label="JGLOBAL_SORT_BY"
            default="a.id DESC"
            class="js-select-submit-on-change"
        >
            <option value="a.id DESC">ID DESC</option>
            <option value="a.id ASC">ID ASC</option>
            <option value="a.bundle_number ASC">Bundle-Nummer ASC</option>
            <option value="a.bundle_number DESC">Bundle-Nummer DESC</option>
            <option value="a.bundle_name ASC">Bundle-Name ASC</option>
            <option value="a.bundle_name DESC">Bundle-Name DESC</option>
            <option value="a.is_active ASC">Status ASC</option>
            <option value="a.is_active DESC">Status DESC</option>
            <option value="a.created DESC">Erstellt DESC</option>
            <option value="a.created ASC">Erstellt ASC</option>
            <option value="a.modified DESC">Geändert DESC</option>
            <option value="a.modified ASC">Geändert ASC</option>
        </field>

        <field
            name="limit"
            type="limitbox"
            default="20"
            class="js-select-submit-on-change"
        />
    </fields>
</form>
