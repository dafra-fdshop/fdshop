<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields>
        <fieldset name="basic" label="Produkt">
            <field
                name="id"
                type="hidden"
                default="0"
            />

            <field
                name="product_name"
                type="text"
                label="Produktname"
                required="true"
                size="40"
            />

            <field
                name="sku"
                type="text"
                label="Artikelnummer (SKU)"
                size="40"
            />

            <field
                name="gtin"
                type="text"
                label="GTIN/EAN"
                size="40"
				description="EAN Code"
            />

            <field
                name="alias"
                type="text"
                label="Alias"
                size="40"
				description="Leer = Wird automatisch gefüllt"
            />

            <field
                name="manufacturer_id"
                type="sql"
                label="Hersteller"
                query="SELECT 0 AS value, '- Kein Hersteller -' AS text UNION SELECT id AS value, manufacturer_name AS text FROM #__fdshop_manufacturers ORDER BY text ASC"
                key_field="value"
                value_field="text"
                default="0"
            />

            <field
                name="category_ids"
                type="sql"
                label="Kategorien"
                query="SELECT id AS value, category_name AS text FROM #__fdshop_categories ORDER BY category_name ASC"
                key_field="value"
                value_field="text"
                multiple="true"
                size="12"
				description="Mehrfachauswahl durch drücken der 'Strg'-Taste"
            />

            <field
                name="buyer_group_ids"
                type="sql"
                label="Käufergruppen"
                query="SELECT id AS value, group_name AS text FROM #__fdshop_buyer_groups WHERE is_active = 1 ORDER BY ordering ASC, group_name ASC"
                key_field="value"
                value_field="text"
                multiple="true"
                size="12"
				description="Mehrfachauswahl durch drücken der 'Strg'-Taste"
            />

            <field
                name="short_description"
                type="textarea"
                label="Kurzbeschreibung"
                rows="4"
                cols="60"
                filter="raw"
            />

            <field
                name="description"
                type="textarea"
                label="Produktbeschreibung"
                rows="8"
                cols="60"
                filter="raw"
            />
        </fieldset>

        <fieldset name="pricing" label="Preis">
            <field
                name="sale_price"
                type="number"
                label="Verkaufspreis"
                step="0.01"
                min="0"
            />

            <field
                name="discount_price"
                type="number"
                label="Rabattpreis"
                step="0.01"
                min="0"
            />

            <field
                name="discount_active"
                type="radio"
                label="Rabatt aktiv"
                default="0"
                class="btn-group btn-group-yesno"
            >
                <option value="1">Ja</option>
                <option value="0">Nein</option>
            </field>

            <field
                name="currency"
                type="text"
                label="Währung"
                size="10"
                default="EUR"
            />
        </fieldset>

        <fieldset name="stock" label="Lager">
            <field
                name="stock_quantity"
                type="number"
                label="Lagerbestand"
                step="1"
                min="0"
            />

            <field
                name="low_stock"
                type="number"
                label="Schwellwert wenig Bestand"
                step="1"
                min="0"
            />

            <field
                name="reserved_quantity"
                type="number"
                label="Reserviert"
                step="0.001"
                min="0"
            />

            <field
                name="sold_quantity"
                type="number"
                label="Verkaufte Menge"
                step="0.001"
                min="0"
            />

            <field
                name="is_in_stock"
                type="radio"
                label="Direkt auf Lager"
                default="0"
                class="btn-group btn-group-yesno"
            >
                <option value="1">Ja</option>
                <option value="0">Nein</option>
            </field>

            <field
                name="available_from"
                type="calendar"
                label="Verfügbar ab"
                format="%Y-%m-%d %H:%M:%S"
                filter="user_utc"
				description="Ab wann vorraussichtlich im Lager"
            />

            <field
                name="min_order_qty"
                type="number"
                label="Mindestbestellmenge"
                step="0.001"
                min="0"
            />

            <field
                name="max_order_qty"
                type="number"
                label="Maximalbestellmenge"
                step="0.001"
                min="0"
            />

            <field
                name="step_order_qty"
                type="number"
                label="Bestellschritt"
                step="0.001"
                min="0"
            />
			
			<field
				name="in_stock"
				type="text"
				label="Bestandsstatus"
				readonly="true"
				class="readonly"
				description="Wird automatisch aus Lagerdaten berechnet"
			/>	
			
        </fieldset>

        <fieldset name="publishing" label="Veröffentlichung">
            <field
                name="katalog_active"
                type="radio"
                label="Katalogmodus aktiv"
				readonly="true"
                class="btn-group btn-group-yesno"
				description="Nur Anzeige. Kann nur Global (Konfiguration) geändert werden"
            >
                <option value="1">Ja</option>
                <option value="0">Nein</option>
            </field>

            <field
                name="is_active"
                type="radio"
                label="Veröffentlicht"
                default="0"
                class="btn-group btn-group-yesno"
            >
                <option value="1">Ja</option>
                <option value="0">Nein</option>
            </field>

            <field
                name="publish_up"
                type="calendar"
                label="Veröffentlichen ab"
                format="%Y-%m-%d %H:%M:%S"
                filter="user_utc"
            />

            <field
                name="publish_down"
                type="calendar"
                label="Veröffentlichen bis"
                format="%Y-%m-%d %H:%M:%S"
                filter="user_utc"
            />
        </fieldset>

        <fieldset name="beschreibung" label="Beschreibung">
            <field
                name="meta_title"
                type="text"
                label="Meta-Titel"
                size="60"
            />

            <field
                name="meta_keywords"
                type="textarea"
                label="Meta-Keywords"
                rows="4"
                cols="60"
                filter="raw"
            />

            <field
                name="meta_description"
                type="textarea"
                label="Meta-Beschreibung"
                rows="4"
                cols="60"
                filter="raw"
            />
        </fieldset>

        <fieldset name="special" label="Besondere Felder">
            <field
                name="unit_type"
                type="text"
                label="Einheitstyp"
                size="40"
            />

            <field
                name="unit_quantity"
                type="number"
                label="Einheitsmenge"
                step="1"
                min="0"
            />

            <field
                name="nem"
                type="number"
                label="NEM"
                step="0.001"
                min="0"
            />

            <field
                name="shot_count"
                type="number"
                label="Schussanzahl"
                step="0.001"
                min="0"
            />

            <field
                name="caliber"
                type="text"
                label="Kaliber"
                size="40"
            />

            <field
                name="burn_time"
                type="text"
                label="Brenndauer"
                size="40"
            />

            <field
                name="rise_height"
                type="text"
                label="Steighöhe"
                size="40"
            />

            <field
                name="ribbon_new"
                type="radio"
                label="Ribbon Neu"
                default="0"
                class="btn-group btn-group-yesno"
            >
                <option value="1">Ja</option>
                <option value="0">Nein</option>
            </field>

            <field
                name="ribbon_hot"
                type="radio"
                label="Ribbon Hot"
                default="0"
                class="btn-group btn-group-yesno"
            >
                <option value="1">Ja</option>
                <option value="0">Nein</option>
            </field>
        </fieldset>

        <fieldset name="dimensions" label="Maße">
            <field
                name="weight"
                type="number"
                label="Gewicht"
                step="0.001"
                min="0"
            />

            <field
                name="length"
                type="number"
                label="Länge"
                step="0.001"
                min="0"
            />

            <field
                name="width"
                type="number"
                label="Breite"
                step="0.001"
                min="0"
            />

            <field
                name="height"
                type="number"
                label="Höhe"
                step="0.001"
                min="0"
            />
        </fieldset>

        <fieldset name="media" label="Medien">
            <field
                name="product_image"
                type="file"
                label="Produktbild"
                accept="image/*"
            />
        </fieldset>
    </fields>
</form>