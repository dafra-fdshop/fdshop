<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields>
        <fieldset name="basic" label="Versandart">
            <field name="id" type="hidden" default="0" />

            <field
                name="shipment_name"
                type="text"
                label="Versandname"
                required="true"
                size="60"
            />

            <field
                name="shipment_description"
                type="textarea"
                label="Beschreibung"
                rows="6"
                cols="60"
                filter="raw"
            />

            <field
                name="shipment_color"
                type="color"
                label="Farbe"
                default="#000000"
            />

            <field
                name="shipment_price"
                type="number"
                label="Versandpreis"
                step="0.0001"
                min="0"
            />

            <field
                name="is_published"
                type="radio"
                label="Veröffentlicht"
                default="1"
                class="btn-group btn-group-yesno"
            >
                <option value="1">Ja</option>
                <option value="0">Nein</option>
            </field>
        </fieldset>
    </fields>
</form>