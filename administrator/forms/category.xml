<?xml version="1.0" encoding="utf-8"?>
<form>
    <fields>
        <fieldset name="basic" label="Kategorie">
            <field
                name="id"
                type="hidden"
                default="0"
            /> 

            <field
                name="category_name"
                type="text"
                label="Kategoriename"
                required="true"
                size="40"
            />

            <field
                name="alias"
                type="text"
                label="Alias"
                size="40"
            />

            <field
                name="parent_id"
                type="sql"
                label="Übergeordnete Kategorie"
                query="SELECT 0 AS value, '- Keine -' AS text UNION SELECT id AS value, category_name AS text FROM #__fdshop_categories ORDER BY text ASC"
                key_field="value"
                value_field="text"
                default="0"
            />

            <field
                name="description"
                type="textarea"
                label="Beschreibung"
                rows="6"
                cols="60"
                filter="raw"
            />

            <field
                name="is_active"
                type="radio"
                label="Aktiv"
                default="1"
                class="btn-group btn-group-yesno"
            >
                <option value="1">Ja</option>
                <option value="0">Nein</option>
            </field>
        </fieldset>
    </fields>
</form>