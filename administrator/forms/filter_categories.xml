<?xml version="1.0" encoding="utf-8"?>
<form>
	<fields name="filter">
		<field
			name="search"
			type="text"
			inputmode="search"
			hint="JSEARCH_FILTER"
		/>

		<field
			name="published"
			type="status"
			class="js-select-submit-on-change"
		/>
	</fields>

	<fields name="list">
		<field
			name="fullordering"
			type="list"
			default="a.ordering ASC"
			class="js-select-submit-on-change"
		>
			<option value="a.ordering ASC">Sortierung ASC</option>
			<option value="a.ordering DESC">Sortierung DESC</option>
			<option value="a.category_name ASC">Name ASC</option>
			<option value="a.category_name DESC">Name DESC</option>
			<option value="a.id ASC">ID ASC</option>
			<option value="a.id DESC">ID DESC</option>
		</field>

		<field
			name="limit"
			type="limitbox"
			default="20"
			class="js-select-submit-on-change"
		/>
	</fields>
</form>